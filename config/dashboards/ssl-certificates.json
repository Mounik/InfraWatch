{
  "dashboard": {
    "id": null,
    "title": "SSL Certificates",
    "tags": ["infrawatch", "ssl", "certificates"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "1h",
    "panels": [
      {
        "id": 1,
        "title": "Days Until Certificate Expiry",
        "type": "table",
        "targets": [{
          "expr": "ssl_cert_not_after - time() / 86400",
          "format": "table",
          "instant": true
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "d",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 14, "color": "yellow"},
                {"value": 30, "color": "green"}
              ]
            }
          },
          "overrides": [{
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [{
              "id": "custom.cellOptions",
              "value": {"type": "color-background"}
            }]
          }]
        },
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Certificates Expiring Soon",
        "type": "stat",
        "targets": [{
          "expr": "count((ssl_cert_not_after - time() / 86400) < 30) or vector(0)",
          "legendFormat": "expiring"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12}
      },
      {
        "id": 3,
        "title": "Total Monitored Domains",
        "type": "stat",
        "targets": [{
          "expr": "count(ssl_cert_not_after) or vector(0)",
          "legendFormat": "domains"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "blue"}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12}
      },
      {
        "id": 4,
        "title": "Certificate Expiry Timeline",
        "type": "bargauge",
        "targets": [{
          "expr": "ssl_cert_not_after - time() / 86400",
          "legendFormat": "{{instance}}"
        }],
        "fieldConfig": {
          "defaults": {
            "unit": "d",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 14, "color": "yellow"},
                {"value": 30, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "templating": {
      "list": [{
        "name": "instance",
        "type": "query",
        "query": "label_values(ssl_cert_not_after, instance)"
      }]
    }
  }
}