all:
  children:
    monitoring:
      hosts:
        monitor01:
          ansible_host: 192.168.1.10
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/id_rsa
          
    agents:
      hosts:
        web01:
          ansible_host: 192.168.1.20
          ansible_user: ubuntu
          labels:
            role: webserver
            env: production
            
        db01:
          ansible_host: 192.168.1.21
          ansible_user: ubuntu
          labels:
            role: database
            env: production
            
        app01:
          ansible_host: 192.168.1.22
          ansible_user: ubuntu
          labels:
            role: application
            env: staging