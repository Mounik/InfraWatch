global:
  smtp_smarthost: '{{ smtp_host }}:587'
  smtp_from: '{{ smtp_from }}'
  smtp_auth_username: '{{ smtp_user }}'
  smtp_auth_password: '{{ smtp_pass }}'

route:
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 12h
  receiver: 'default'
  routes:
    - match:
        severity: critical
      receiver: 'critical'
    - match:
        severity: warning
      receiver: 'warning'

receivers:
  - name: 'default'
    email_configs:
      - to: '{{ alert_email }}'

  - name: 'critical'
    email_configs:
      - to: '{{ alert_email }}'
        headers:
          Subject: '[CRITICAL] {{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
{% if discord_webhook %}
    webhook_configs:
      - url: '{{ discord_webhook }}'
        send_resolved: true
{% endif %}

  - name: 'warning'
    email_configs:
      - to: '{{ alert_email }}'

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'instance']

  - source_match:
      alertname: 'NodeDown'
    target_match_re:
      alertname: '.*'
    equal: ['instance']